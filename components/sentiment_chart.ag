<template>
  <div class="chart-container">
    <div class="bar-row">
      <div class="label">Positive</div>
      <div class="bar-track">
        <div class="bar-fill positive" :style="{ width: `${scores['Positive'] * 100}%` }"></div>
      </div>
      <div class="value">{{ (scores['Positive'] * 100).toFixed(1) }}%</div>
    </div>
    
    <div class="bar-row">
      <div class="label">Neutral</div>
      <div class="bar-track">
        <div class="bar-fill neutral" :style="{ width: `${scores['Neutral'] * 100}%` }"></div>
      </div>
      <div class="value">{{ (scores['Neutral'] * 100).toFixed(1) }}%</div>
    </div>
    
    <div class="bar-row">
      <div class="label">Negative</div>
      <div class="bar-track">
        <div class="bar-fill negative" :style="{ width: `${scores['Negative'] * 100}%` }"></div>
      </div>
      <div class="value">{{ (scores['Negative'] * 100).toFixed(1) }}%</div>
    </div>
  </div>
</template>

<script>
export default {
  props: {
    scores: {
      type: Object,
      required: true,
      default: () => ({ Positive: 0, Neutral: 0, Negative: 0 })
    }
  }
}
</script>

<style scoped>
.chart-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1rem 0;
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.label {
  width: 70px;
  text-align: right;
  font-weight: 500;
  font-size: 0.9rem;
}

.bar-track {
  flex: 1;
  height: 12px;
  background-color: #333;
  border-radius: 6px;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6px;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.bar-fill.positive { background-color: #10b981; }
.bar-fill.neutral { background-color: #9ca3af; }
.bar-fill.negative { background-color: #ef4444; }

.value {
  width: 50px;
  text-align: right;
  font-size: 0.9rem;
  font-variant-numeric: tabular-nums;
}
</style>
